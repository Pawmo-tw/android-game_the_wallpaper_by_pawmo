<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="60dp"
            android:text="all the wallpaper by pawmo"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- GAME  -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="30dp"
            android:text="GAME"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:id="@+id/llDino"
                style="@style/OptionContainerStyle">
                <ImageView
                    android:id="@+id/ivClassic"
                    style="@style/IconStyle"
                    android:src="@drawable/dino_run1" />
                <TextView
                    style="@style/TextStyle"
                    android:text="Dino" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llFlappy"
                style="@style/OptionContainerStyle">
                <ImageView
                    android:id="@+id/ivFlappy"
                    style="@style/IconStyle"
                    android:src="@drawable/flappy_bird" />
                <TextView
                    style="@style/TextStyle"
                    android:text="Flappy" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llCoreball"
                style="@style/OptionContainerStyle">
                <ImageView
                    android:id="@+id/ivCoreball"
                    style="@style/IconStyle"
                    android:src="@drawable/coreball" />
                <TextView
                    style="@style/TextStyle"
                    android:text="Coreball" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:id="@+id/ll2048"
                style="@style/OptionContainerStyle">
                <ImageView
                    android:id="@+id/iv2048"
                    style="@style/IconStyle"
                    android:src="@drawable/game_2048_icon" />
                <TextView
                    style="@style/TextStyle"
                    android:text="2048" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llCrossy"
                style="@style/OptionContainerStyle">
                <ImageView
                    android:id="@+id/ivCrossy"
                    style="@style/IconStyle"
                    android:src="@drawable/crossy_icon" />
                <TextView
                    style="@style/TextStyle"
                    android:text="Crossy" />
            </LinearLayout>

            <!-- 佔位  -->
            <View
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <!-- GRAVITY  -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="30dp"
            android:text="Gravity"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:id="@+id/llMatrix"
                style="@style/OptionContainerStyle">
                <ImageView
                    style="@style/SmallIconStyle"
                    android:src="@drawable/matrix_icon" />
                <TextView
                    style="@style/SmallTextStyle"
                    android:text="Matrix" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llParticles"
                style="@style/OptionContainerStyle">
                <ImageView
                    style="@style/SmallIconStyle"
                    android:src="@drawable/particle_icon" />
                <TextView
                    style="@style/SmallTextStyle"
                    android:text="Stars" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llLiquid"
                style="@style/OptionContainerStyle">
                <ImageView
                    style="@style/SmallIconStyle"
                    android:src="@drawable/liquid_icon" />
                <TextView
                    style="@style/SmallTextStyle"
                    android:text="Liquid" />
            </LinearLayout>
        </LinearLayout>

        <!-- SIMULATE  -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="30dp"
            android:text="simulate"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/llAdvanced"
                style="@style/OptionContainerStyle">
                <ImageView
                    style="@style/SmallIconStyle"
                    android:src="@drawable/ripple_icon" />
                <TextView
                    style="@style/SmallTextStyle"
                    android:text="Ripple" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llLine"
                style="@style/OptionContainerStyle">
                <ImageView
                    style="@style/SmallIconStyle"
                    android:src="@drawable/line_icon" />
                <TextView
                    style="@style/SmallTextStyle"
                    android:text="Line" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>
        <!-- UPLOAD  -->
        <LinearLayout
            android:id="@+id/llUpload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground">


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="Upload Custom (MP4/GIF)"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>